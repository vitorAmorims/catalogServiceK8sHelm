# Source: play-catalog/templates/deployment.yaml
apiVersion: apps/v1
kind: Deployment
metadata:
  name: release-name-play-catalog
  labels:
    helm.sh/chart: play-catalog-0.1.0
    app.kubernetes.io/name: play-catalog
    app.kubernetes.io/instance: release-name
    app.kubernetes.io/version: "1.16.0"
    app.kubernetes.io/managed-by: Helm
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: play-catalog
      app.kubernetes.io/instance: release-name
  template:
    metadata:
      labels:
        helm.sh/chart: play-catalog-0.1.0
        app.kubernetes.io/name: play-catalog
        app.kubernetes.io/instance: release-name
        app.kubernetes.io/version: "1.16.0"
        app.kubernetes.io/managed-by: Helm
    spec:
      serviceAccountName: release-name-play-catalog
      containers:
        - name: play-catalog
          image: "vtamorims/catalog-services:latest"
          imagePullPolicy: IfNotPresent
          env:
            # Loop que injeta automaticamente tudo o que estiver abaixo de 'webapi.env'
            - name: "AllowedOrigin"
              value: "http://localhost:3000"
            - name: "MongoDbSettings__Host"
              value: "play-catalog-service-mongodb"
            - name: "MongoDbSettings__Port"
              value: "27017"
            - name: "RabbitMQSettings__Host"
              value: "play-catalog-service-rabbitmq"
            - name: "RabbitMQSettings__Port"
              value: "5672"
            - name: "ServiceSettings__ServiceName"
              value: "Catalog"
          ports:
            - name: http
              containerPort: 80
              protocol: TCP
          livenessProbe:
            httpGet:
              path: /
              port: http
          readinessProbe:
            httpGet:
              path: /
              port: http

